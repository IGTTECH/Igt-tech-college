    <!-- STEP-BY-STEP FLOW GUIDE -->
    <section id="intambwe" class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Uburyo App Ikoreshwa Intambwe ku Yindi</h2>
                <p class="text-slate-600 text-base">Kurikira izi ntambwe 4 zikurikira kugira ngo ubone ubumenyi bwuzuye kandi utsindire n'impamyabumenyi zawe.</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 relative">
                <!-- Line helper for desktop -->
                <div class="hidden lg:block absolute top-1/2 left-4 right-4 h-0.5 bg-indigo-100 -translate-y-8 z-0"></div>

                <!-- Step 1 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative z-10 flex flex-col h-full hover:shadow-md transition">
                    <div class="w-12 h-12 bg-indigo-600 text-white font-bold text-lg rounded-full flex items-center justify-center mb-6 shadow-md shadow-indigo-200">
                        1
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2">Hitamo Igice Ushaka Kwigamo</h3>
                    <p class="text-slate-500 text-sm leading-relaxed flex-grow">
                        Koresha tab ya <strong>"Amasomo"</strong> yo kwiga amasomo rusange, cyangwa uhitemo <strong>"Aba Tekinisiye"</strong> niba ushaka ubumenyi bwihariye bwo gusana telefone (Electronics, Soldering, Multimeter n'ibindi).
                    </p>
                </div>

                <!-- Step 2 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative z-10 flex flex-col h-full hover:shadow-md transition">
                    <div class="w-12 h-12 bg-indigo-600 text-white font-bold text-lg rounded-full flex items-center justify-center mb-6 shadow-md shadow-indigo-200">
                        2
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2">Soma Amasomo & Gukora Quiz</h3>
                    <p class="text-slate-500 text-sm leading-relaxed flex-grow">
                        Soma neza isomo ryawe kugeza hasi, hanyuma ukore <strong>Quiz (ikizamini gito)</strong> kigufasha kugenzura ubumenyi umaze kugira. Ibi bigufasha kubika amanota no gufungura isomo ririkurikira.
                    </p>
                </div>

                <!-- Step 3 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative z-10 flex flex-col h-full hover:shadow-md transition">
                    <div class="w-12 h-12 bg-indigo-600 text-white font-bold text-lg rounded-full flex items-center justify-center mb-6 shadow-md shadow-indigo-200">
                        3
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2">Reba Aho Ugeze kuri Dashboard</h3>
                    <p class="text-slate-500 text-sm leading-relaxed flex-grow">
                        Kuri tab ya <strong>"Amasomo"</strong>, uzabona amakuru yawe yose ahari: umubare w'amasomo umaze kurangiza, ijanisha ry'aho ugeze (%), n'amanota ubona mu bizamini byose bya Quiz.
                    </p>
                </div>

                <!-- Step 4 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative z-10 flex flex-col h-full hover:shadow-md transition">
                    <div class="w-12 h-12 bg-indigo-600 text-white font-bold text-lg rounded-full flex items-center justify-center mb-6 shadow-md shadow-indigo-200">
                        4
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2">Fata Impamya Bushobozi</h3>
                    <p class="text-slate-500 text-sm leading-relaxed flex-grow">
                        Nyuma yo kurangiza amasomo yose n'ibizamini ku gice runaka (nka Cyber Security), andika izina ryawe uhite uhabwa <strong>Impamya bushobozi (Certificate)</strong> uyibike kuri telefone cyangwa uyisangize abandi.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- KEY MODULES EXPLAINED -->
    <section id="ibice-byingenzi" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Ibigize Buri Gice muri App</h2>
