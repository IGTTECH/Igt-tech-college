    <!-- JAVASCRIPT FOR INTERACTION -->
    <script>
        // Tab Switcher for Phone Mockup
        function switchTab(tabId) {
            // Hide all screens
            const screens = document.querySelectorAll('.screen-content');
            screens.forEach(s => s.classList.add('hidden'));

            // Show selected screen
            document.getElementById('screen-' + tabId).classList.remove('hidden');

            // Reset tab button border and backgrounds
            const buttons = document.querySelectorAll('.tab-btn');
            buttons.forEach(b => {
                b.classList.remove('border-indigo-600', 'bg-indigo-950/40');
                b.classList.add('border-slate-800', 'bg-slate-900/50');
                b.querySelector('h4').classList.remove('text-white');
                b.querySelector('h4').classList.add('text-slate-300');
            });

            // Highlight selected left button
            const selectedBtn = document.getElementById('btn-' + tabId);
            if (selectedBtn) {
                selectedBtn.classList.add('border-indigo-600', 'bg-indigo-950/40');
                selectedBtn.classList.remove('border-slate-800', 'bg-slate-900/50');
                selectedBtn.querySelector('h4').classList.add('text-white');
                selectedBtn.querySelector('h4').classList.remove('text-slate-300');
            }

            // Highlight mockup nav
            const navIds = ['amasomo', 'tekinisiye', 'ibikoresho', 'amagenamiterere'];
            navIds.forEach(id => {
                const navBtn = document.getElementById('mock-nav-' + id);
                if (id === tabId) {
                    navBtn.className = "flex flex-col items-center text-indigo-500";
                } else {
                    navBtn.className = "flex flex-col items-center text-slate-500";
                }
            });
        }

        // Toggle FAQs Accordion
        function toggleFaq(index) {
            const answer = document.getElementById('faq-ans-' + index);
            const icon = document.getElementById('faq-icon-' + index);

            if (answer.classList.contains('hidden')) {
                answer.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                answer.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }

        // Initial setup
        switchTab('amasomo');
    </script>
